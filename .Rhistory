orders$order_delivered_customer_date <- ymd_hms(orders$order_delivered_customer_date, quiet=TRUE)
orders$order_estimated_delivery_date <- ymd_hms(orders$order_estimated_delivery_date, quiet=TRUE)
str(orders[, c("order_purchase_timestamp","order_delivered_customer_date")])
# -- 2.2 Variables calculees -------------------------------------------
