# ======================================================================
# CHAPITRE 2 - STRUCTURES DE DONNEES APPLIQUEES SUR OLIST
# ======================================================================
# -- Vecteurs extraits du dataset --------------------------------------
# c() : vecteur de statistiques resumees manuellement
stats_payment <- c(
min    = min(df$payment_value,    na.rm=TRUE),
q1     = quantile(df$payment_value, 0.25, na.rm=TRUE),
median = median(df$payment_value, na.rm=TRUE),
mean   = mean(df$payment_value,   na.rm=TRUE),
q3     = quantile(df$payment_value, 0.75, na.rm=TRUE),
max    = max(df$payment_value,    na.rm=TRUE)
)
print(stats_payment)
# Sequence de seuils pour analyser les tranches de panier
tranches <- seq(from=0, to=1000, by=100)
# seq(from, to, by) -> vecteur regulier
print(tranches)
# rep() : construire un vecteur de labels
labels_tranches <- rep("BRL", length(tranches))
# rep(valeur, n) -> repeter n fois
# Indexation : isoler les commandes dont le panier > Q3
payment_vect <- df$payment_value
payment_vect[payment_vect > q3][1:10]   # 10 premieres valeurs > Q3
payment_vect[-(1:100)][1:5]             # exclure les 100 premieres
# Operations vectorielles : calcul de commission 5% sur chaque commande
commission <- df$payment_value * 0.05
cat("Commission totale estimee (5%) :", round(sum(commission, na.rm=TRUE), 0), "BRL\n")
length(commission)   # nombre de commandes
# Statistiques de base vectorielles sur delivery_days
jours <- df$delivery_days
mean(jours,   na.rm=TRUE)   # delai moyen
median(jours, na.rm=TRUE)   # delai median (plus robuste)
sum(jours,    na.rm=TRUE)   # total de jours de livraison cumules
sd(jours,     na.rm=TRUE)   # ecart-type
var(jours,    na.rm=TRUE)   # variance
range(jours,  na.rm=TRUE)   # [min, max]
rank(head(jours, 20))       # rang des 20 premiers delais
# -- Facteurs : variables qualitatives Olist ----------------------------
# factor() : convertir payment_type en facteur
df$payment_type <- factor(df$payment_type)
# as.factor() fait la meme chose
df$delivery_speed <- as.factor(df$delivery_speed)
