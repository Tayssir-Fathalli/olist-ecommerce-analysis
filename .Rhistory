# -----------------------------------------------------------------------
# Fonction : installe le package si absent, puis le charge
# Executer ce bloc EN ENTIER (Ctrl+A puis Ctrl+Enter) avant tout le reste
# -----------------------------------------------------------------------
charger <- function(pkg) {
if (!requireNamespace(pkg, quietly=TRUE)) {
cat("  Installation de", pkg, "...\n")
install.packages(pkg,
dependencies = TRUE,
repos        = "https://cloud.r-project.org")
}
library(pkg, character.only=TRUE)
cat("  OK :", pkg, "\n")
}
View(charger)
cat("=== Chargement des packages ===\n")
charger("dplyr")       # manipulation : filter, mutate, group_by, summarise
charger("ggplot2")     # visualisation en couches
charger("lubridate")   # gestion des dates
charger("tidyr")       # drop_na, pivot
charger("corrplot")    # heatmap de correlations
charger("factoextra")  # fviz_eig, fviz_pca_var, fviz_ca_biplot
charger("FactoMineR")  # PCA(), CA()
charger("cluster")     # silhouette
charger("plotrix")     # pie3D
charger("scales")      # formatage des axes
# # ======================================================================
#         ANALYSE STATISTIQUE DU DATASET OLIST - EN R
#   Chapitres 1 a 6 appliques sur les donnees Olist
#   3 fichiers CSV : orders, payments, order_items
# ======================================================================
#
# COMMENT UTILISER CE SCRIPT :
#   1. Placer les 3 fichiers CSV Olist dans un meme dossier
#   2. Modifier le chemin dans setwd() ci-dessous
#   3. Executer le script section par section (Ctrl+Enter dans RStudio)
# ======================================================================
# ======================================================================
# 0. LIBRAIRIES ET REPERTOIRE DE TRAVAIL
# ======================================================================
# -----------------------------------------------------------------------
# Fonction : installe le package si absent, puis le charge
# Executer ce bloc EN ENTIER (Ctrl+A puis Ctrl+Enter) avant tout le reste
# -----------------------------------------------------------------------
charger <- function(pkg) {
if (!requireNamespace(pkg, quietly=TRUE)) {
cat("  Installation de", pkg, "...\n")
install.packages(pkg,
dependencies = TRUE,
repos        = "https://cloud.r-project.org")
}
library(pkg, character.only=TRUE)
cat("  OK :", pkg, "\n")
}
cat("=== Chargement des packages ===\n")
charger("dplyr")       # manipulation : filter, mutate, group_by, summarise
charger("ggplot2")     # visualisation en couches
charger("lubridate")   # gestion des dates
charger("tidyr")       # drop_na, pivot
charger("corrplot")    # heatmap de correlations
charger("factoextra")  # fviz_eig, fviz_pca_var, fviz_ca_biplot
charger("FactoMineR")  # PCA(), CA()
charger("cluster")     # silhouette
charger("plotrix")     # pie3D
charger("scales")      # formatage des axes
charger("forcats")     # fct_infreq
charger("cubature")    # adaptIntegrate
charger("MASS")        # kde2d
cat("=== Tous les packages sont prets ===\n")
# setwd() : definir le dossier contenant les 3 fichiers CSV
setwd("C:/Users/VotreNom/Downloads/olist")
# setwd() : definir le dossier contenant les 3 fichiers CSV
setwd("C:C:/Users/Mega-PC/Downloads/orders_analysis")
# setwd() : definir le dossier contenant les 3 fichiers CSV
setwd("C:/Users/Mega-PC/Downloads/orders_analysis")
# setwd() : definir le dossier contenant les 3 fichiers CSV
setwd("C:/Users/Mega-PC/Downloads/orders_analysis")
getwd()   # verifier le repertoire courant
# ======================================================================
# 1. CHARGEMENT DES 3 DATASETS (Chapitre 3 - read.csv)
# ======================================================================
# read.csv() lit un fichier CSV -> data frame
# header=TRUE  : 1re ligne = noms de colonnes
# stringsAsFactors=FALSE : ne pas convertir le texte en facteurs
orders      <- read.csv("olist_orders_dataset.csv",
header=TRUE, stringsAsFactors=FALSE)
payments    <- read.csv("olist_order_payments_dataset.csv",
header=TRUE, stringsAsFactors=FALSE)
order_items <- read.csv("olist_order_items_dataset.csv",
header=TRUE, stringsAsFactors=FALSE)
# -- Exploration initiale (Chapitre 3) ---------------------------------
# dim() : dimensions (lignes, colonnes)
dim(orders)
dim(payments)
dim(order_items)
# head() : premieres lignes
head(orders)
head(payments)
head(order_items)
# str() : types de colonnes et echantillon de valeurs
str(orders)
str(payments)
str(order_items)
# names() : noms de toutes les colonnes
names(orders)
names(payments)
names(order_items)
# summary() : statistiques descriptives par colonne
summary(orders)
summary(payments)
summary(order_items)
# Valeurs manquantes par colonne
colSums(is.na(orders))
colSums(is.na(payments))
colSums(is.na(order_items))
# Doublons
sum(duplicated(orders))
sum(duplicated(payments))
sum(duplicated(order_items))
# write.table() : exporter un data frame en CSV
# write.table(orders, file="orders_export.csv", col.names=TRUE, sep=";")
# ======================================================================
# 2. NETTOYAGE ET CONSTRUCTION DU DATAFRAME PRINCIPAL
# ======================================================================
# -- 2.1 Convertir les dates (chr -> POSIXct) ---------------------------
# ymd_hms() du package lubridate : "YYYY-MM-DD HH:MM:SS" -> datetime
orders$order_purchase_timestamp      <- ymd_hms(orders$order_purchase_timestamp,      quiet=TRUE)
orders$order_delivered_customer_date <- ymd_hms(orders$order_delivered_customer_date, quiet=TRUE)
orders$order_estimated_delivery_date <- ymd_hms(orders$order_estimated_delivery_date, quiet=TRUE)
str(orders[, c("order_purchase_timestamp","order_delivered_customer_date")])
# -- 2.2 Variables calculees -------------------------------------------
# difftime() : difference entre deux dates en jours
orders$delivery_days <- as.numeric(
difftime(orders$order_delivered_customer_date,
orders$order_purchase_timestamp, units="days"))
orders$delivery_delay <- as.numeric(
difftime(orders$order_delivered_customer_date,
orders$order_estimated_delivery_date, units="days"))
# Positif = retard, negatif = avance
# wday() : jour de la semaine
orders$order_dayofweek <- wday(orders$order_purchase_timestamp,
label=TRUE, abbr=FALSE)
# month() : mois (1 a 12)
orders$order_month <- month(orders$order_purchase_timestamp)
# year() : annee
orders$order_year  <- year(orders$order_purchase_timestamp)
# -- 2.3 Filtrer les commandes livrees uniquement -----------------------
# filter() de dplyr : selectionner les lignes selon une condition
df <- orders %>%
filter(order_status == "delivered") %>%
drop_na(delivery_days)
cat("Commandes livrees propres :", nrow(df), "\n")
# -- 2.4 Agregation des paiements par commande -------------------------
# group_by + summarise : equivalent groupby().agg() en Python
payments_agg <- payments %>%
group_by(order_id) %>%
summarise(
payment_value        = sum(payment_value,        na.rm=TRUE),
payment_type         = first(payment_type),
payment_installments = max(payment_installments, na.rm=TRUE)
)
# -- 2.5 Fusion orders + payments + order_items ------------------------
# merge() : LEFT JOIN entre deux data frames
df <- merge(df, payments_agg, by="order_id", all.x=TRUE)
# Valeur totale + frais par commande depuis order_items
items_agg <- order_items %>%
group_by(order_id) %>%
summarise(
total_price    = sum(price,         na.rm=TRUE),
total_freight  = sum(freight_value, na.rm=TRUE),
nb_items       = max(order_item_id, na.rm=TRUE)
)
df <- merge(df, items_agg, by="order_id", all.x=TRUE)
df <- drop_na(df, payment_value, delivery_days)
# -- 2.6 Variables qualitatives derivees ------------------------------
# case_when() : if/elif/else vectorise
df <- df %>%
mutate(
late_delivery = ifelse(delivery_delay > 0, "Oui", "Non"),
delivery_speed = case_when(
delivery_days <= 7  ~ "Rapide",
delivery_days <= 20 ~ "Normal",
TRUE                ~ "Lent"
),
satisfaction = case_when(
review_score >= 4           ~ "Positive",
review_score == 3           ~ "Neutre",
review_score <  3           ~ "Negative",
is.na(review_score)         ~ NA_character_
)
)
names(df)
# Ajouter apres le chargement des 3 autres CSV
reviews <- read.csv("olist_order_reviews_dataset.csv",
header=TRUE, stringsAsFactors=FALSE)
# Garder uniquement order_id + review_score
reviews_agg <- reviews %>%
group_by(order_id) %>%
summarise(review_score = mean(review_score, na.rm=TRUE))
# Fusionner avec df (apres le merge existant)
df <- merge(df, reviews_agg, by="order_id", all.x=TRUE)
names(df)
# review_score vient de orders -> peut etre NA ; on le laisse pour les analyses
cat("\nDimensions du dataframe final :", nrow(df), "x", ncol(df), "\n")
cat("Colonnes :\n"); print(names(df))
df <- df %>%
mutate(
late_delivery = ifelse(delivery_delay > 0, "Oui", "Non"),
delivery_speed = case_when(
delivery_days <= 7  ~ "Rapide",
delivery_days <= 20 ~ "Normal",
TRUE                ~ "Lent"
),
satisfaction = case_when(
review_score >= 4    ~ "Positive",
review_score == 3    ~ "Neutre",
review_score <  3    ~ "Negative",
is.na(review_score)  ~ NA_character_
)
)
cat("Colonnes :", ncol(df), "\n")
print(names(df))
df <- df %>%
mutate(
late_delivery = ifelse(delivery_delay > 0, "Oui", "Non"),
delivery_speed = case_when(
delivery_days <= 7  ~ "Rapide",
delivery_days <= 20 ~ "Normal",
TRUE                ~ "Lent"
),
satisfaction = case_when(
review_score >= 4    ~ "Positive",
review_score == 3    ~ "Neutre",
review_score <  3    ~ "Negative",
is.na(review_score)  ~ NA_character_
)
)
cat("Colonnes :", ncol(df), "\n")
print(names(df))
# ======================================================================
# CHAPITRE 1 - BASES DU LANGAGE APPLIQUEES SUR OLIST
# ======================================================================
# Operations arithmetiques sur des valeurs Olist
n_orders   <- nrow(df)
n_orders^2                         # carre du nombre de commandes
sqrt(n_orders)                     # racine carree
(mean(df$payment_value, na.rm=TRUE) + median(df$payment_value, na.rm=TRUE)) / 2
# Afficher une variable calculee
panier_moyen <- mean(df$payment_value, na.rm=TRUE)
print(panier_moyen)
cat("Panier moyen :", round(panier_moyen, 2), "BRL\n")
# sample() : tirer un echantillon aleatoire d'order_ids
set.seed(42)
sample(df$order_id, 5)             # 5 commandes au hasard
# Simulation : si chaque commande avait une note aleatoire de 1 a 5
sample(1:5, 10, replace=TRUE)
# Vecteur des payment_types possibles - tirage pondere par leurs frequences
freq_type <- prop.table(table(df$payment_type))
sample(names(freq_type), 10, replace=TRUE, prob=as.numeric(freq_type))
# Loi binomiale : sur 10 commandes, probabilite d'avoir exactement k retards
# P(retard) estimee depuis les donnees
p_retard <- mean(df$late_delivery == "Oui", na.rm=TRUE)
cat("Probabilite estimee de retard :", round(p_retard, 3), "\n")
x_bin <- 0:10
y_bin <- dbinom(x_bin, size=10, prob=p_retard)
plot(x_bin, y_bin, type="h", lwd=20,
main=paste0("Loi B(10, ", round(p_retard,2), ") - retards sur 10 commandes"),
xlab="Nombre de retards", ylab="P(X=k)", lend="square",
col="steelblue")
# INTERPRETATION : pic a k=1 ou k=2 -> sur 10 commandes, 1-2 retards attendus
# Courbe de densite de la loi normale - centre sur le panier moyen
mu_pay <- mean(df$payment_value, na.rm=TRUE)
sd_pay <- sd(df$payment_value,   na.rm=TRUE)
curve(dnorm(x, mean=mu_pay, sd=sd_pay),
from=mu_pay - 3*sd_pay, to=mu_pay + 3*sd_pay,
main="Densite normale ajustee sur payment_value",
xlab="Montant (BRL)", ylab="Densite", col="darkblue", lwd=2)
# La distribution reelle est asymetrique -> cette courbe est une approximation
# Integration : P(payment_value entre Q1 et Q3) sous la loi normale ajustee
q1 <- quantile(df$payment_value, 0.25, na.rm=TRUE)
q3 <- quantile(df$payment_value, 0.75, na.rm=TRUE)
f_norm <- function(x) dnorm(x, mean=mu_pay, sd=sd_pay)
integrate(f_norm, lower=q1, upper=q3)
# Theoriquement ~ 50% ; en pratique differe car la distribution n'est pas normale
# Integration multivariee : densite sur [0,1]^3 (Chapitre 1 - cubature)
f_multi <- function(x) { 2/3 * (x[1] + x[2] + x[3]) }
adaptIntegrate(f_multi, lowerLimit=c(0,0,0), upperLimit=c(1,1,1))
# Resultat attendu : 1 (densite integre a 1 sur le cube unitaire)
# ======================================================================
# 2. NETTOYAGE ET CONSTRUCTION DU DATAFRAME PRINCIPAL
# ======================================================================
