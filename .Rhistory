df <- orders %>%
filter(order_status == "delivered") %>%
drop_na(delivery_days)
cat("Commandes livrees propres :", nrow(df), "\n")
# -- 2.4 Agregation des paiements par commande -------------------------
# group_by + summarise : equivalent groupby().agg() en Python
payments_agg <- payments %>%
